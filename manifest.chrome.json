{
    "manifest_version": 3,
    "name": "Product Parser",
    "description": "Расширение для извлечения информации о товарах с любых сайтов.",
    "action": {
      "default_popup": "index.html",
      "default_title": "Web Parsing Toolkit"
    },
    "background": {
      "service_worker": "src/background/index.ts",
      "type": "module"
    },
    "icons": {
      "16": "public/icons/icon.png",
      "32": "public/icons/icon.png",
      "48": "public/icons/icon.png"
    },
    "permissions": [
      "storage",
      "tabs",
      "scripting",
      "activeTab",
      "downloads",
      "contextMenus",
      "declarativeNetRequest",
      "declarativeNetRequestWithHostAccess"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "web_accessible_resources": []
  }