{
  "manifest_version": 3,
  "name": "Product Parser",
  "description": "Расширение для извлечения информации о товарах с любых сайтов.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Web Parsing Toolkit"
  },
  "background": {
    "scripts": [
      "src/background/index.ts"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/index.ts"
      ],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "product-parser@samuelgambino.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "public/icons/icon.png",
    "32": "public/icons/icon.png",
    "48": "public/icons/icon.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "downloads",
    "contextMenus",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": []
}