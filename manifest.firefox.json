{
    "manifest_version": 3,
    "name": "Product Parser",
    "description": "Расширение для извлечения информации о товарах с любых сайтов.",
    "action": {
      "default_popup": "index.html",
      "default_title": "Web Parsing Toolkit"
    },
    "background": {
      "scripts": ["src/background/index.ts"],
      "type": "module"
    },
    "browser_specific_settings": {
      "gecko": {
        "id": "product-parser@samuelgambino.com",
        "strict_min_version": "109.0"
      }
    },
    "icons": {
      "16": "public/icons/icon.png",
      "32": "public/icons/icon.png",
      "48": "public/icons/icon.png"
    },
    "permissions": [
      "storage",
      "tabs",
      "scripting",
      "activeTab",
      "downloads",
      "contextMenus",
      "declarativeNetRequest"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "web_accessible_resources": []
  }